# Copy to .env and adjust. Real .env is gitignored.
# Ports are picked in the 7xxx range to avoid clashes with anything
# the developer might already run locally (Vite/Next on 3000, Rails on 4000,
# system Postgres on 5432, Redis on 6379, MinIO on 9000, etc).

# --- Database ---
DATABASE_URL="postgresql://worktrack:worktrack@localhost:7432/worktrack?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:7379/0"

# --- Backend ---
BACKEND_PORT=7340
BACKEND_HOST=0.0.0.0
DASHBOARD_ORIGIN="http://localhost:7330"
LOG_LEVEL=info

# JWT key files (RS256). Generate via:
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# Master KEK for screenshot/PII encryption (32 bytes, base64).
# Generate via: openssl rand -base64 32
MASTER_KEK_BASE64=

# --- Storage (MinIO / S3) ---
S3_ENDPOINT=http://localhost:7900
S3_REGION=us-east-1
S3_ACCESS_KEY=worktrack
S3_SECRET_KEY=worktrack-dev-secret
S3_BUCKET=worktrack
S3_FORCE_PATH_STYLE=true

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:7340
