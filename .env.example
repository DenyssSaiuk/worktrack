# Copy to .env and adjust. Real .env is gitignored.

# --- Database ---
DATABASE_URL="postgresql://worktrack:worktrack@localhost:5432/worktrack?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379/0"

# --- Backend ---
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
DASHBOARD_ORIGIN="http://localhost:3000"
LOG_LEVEL=info

# JWT key files (RS256). Generate via:
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem

# Master KEK for screenshot/PII encryption (32 bytes, base64).
# Generate via: openssl rand -base64 32
MASTER_KEK_BASE64=

# --- Storage (MinIO / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=worktrack
S3_SECRET_KEY=worktrack-dev-secret
S3_BUCKET=worktrack
S3_FORCE_PATH_STYLE=true

# --- AI (optional) ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:4000
