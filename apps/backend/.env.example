# Backend dev environment.
NODE_ENV=development
LOG_LEVEL=debug

DATABASE_URL=postgresql://worktrack:worktrack@localhost:7432/worktrack?schema=public
REDIS_URL=redis://localhost:7379/0

BACKEND_HOST=0.0.0.0
BACKEND_PORT=7340
DASHBOARD_ORIGIN=http://localhost:7330

# Generate via `pnpm keys:generate` (writes to ../../secrets/).
JWT_PRIVATE_KEY_PATH=../../secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=../../secrets/jwt-public.pem

# 32-byte master key, base64-encoded. Generate via:
#   openssl rand -base64 32
MASTER_KEK_BASE64=

# S3 / MinIO
S3_ENDPOINT=http://localhost:7900
S3_REGION=us-east-1
S3_ACCESS_KEY=worktrack
S3_SECRET_KEY=worktrack-dev-secret
S3_BUCKET=worktrack
S3_FORCE_PATH_STYLE=true
