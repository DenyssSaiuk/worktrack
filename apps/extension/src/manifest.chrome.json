{
  "manifest_version": 3,
  "name": "WorkTrack",
  "short_name": "WorkTrack",
  "description": "Reports browser activity to the WorkTrack desktop agent during scheduled work hours.",
  "version": "0.1.0",
  "minimum_chrome_version": "110",
  "permissions": ["tabs", "storage", "alarms", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "WorkTrack"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
