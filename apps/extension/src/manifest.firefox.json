{
  "manifest_version": 3,
  "name": "WorkTrack",
  "short_name": "WorkTrack",
  "description": "Reports browser activity to your WorkTrack workspace during your active workday.",
  "version": "0.2.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "worktrack@worktrack.local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost:7340/*", "https://*/*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "WorkTrack"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
