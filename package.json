{
  "name": "worktrack",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted employee time tracking and productivity analytics.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@worktrack/backend",
    "dev:dashboard": "turbo run dev --filter=@worktrack/dashboard",
    "dev:agent": "turbo run dev --filter=@worktrack/agent",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:migrate": "pnpm --filter @worktrack/database run db:migrate",
    "db:migrate:deploy": "pnpm --filter @worktrack/database run db:migrate:deploy",
    "db:seed": "pnpm --filter @worktrack/database run db:seed",
    "db:reset": "pnpm --filter @worktrack/database run db:reset",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@worktrack/config": "workspace:*",
    "eslint": "^8.57.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
